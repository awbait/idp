# Copy to .env and adjust. Each variable is grouped by area. Uncommented lines
# show this example's recommended value; commented lines are optional or only
# needed in a specific mode (noted inline).
#
# NOTE: the BUILT-IN defaults for HARBOR_MODE/GITLAB_MODE/ARGOCD_MODE are now
# "real" (so a misconfigured deploy fails loudly instead of silently faking).
# This example overrides them to "fake" below for a zero-infra local run
# (in-memory store/cache, no Harbor/GitLab/Argo/Keycloak needed).

# =============================================================================
# Server
# =============================================================================
HTTP_PORT=8080
# Prometheus /metrics is served on this separate port (not the API port), so
# scraping stays internal and is not exposed via the public app ingress.
METRICS_PORT=2112
PUBLIC_URL=http://localhost:8080
# Optional: external Grafana base URL. When set, the status page shows a
# "view in Grafana" link (deep metrics live in Grafana, not the portal).
# GRAFANA_URL=http://localhost:3000
# Secure flag on the session cookie. Default true (production is HTTPS, and
# localhost is a secure context even over http). Set false only for a
# non-localhost plain-HTTP setup.
COOKIE_SECURE=true

# =============================================================================
# Upstream modes — fake|real (per upstream, independent)
# Built-in default is "real" (needs the connection vars below). Fakes run fully
# in-memory and exist for tests + explicit local dev; set them here when running
# without infra. The vendored chart under internal/harbor/charts is fake/test
# only — in real mode the catalog source is Harbor.
# =============================================================================
HARBOR_MODE=fake
GITLAB_MODE=fake
ARGOCD_MODE=fake

# =============================================================================
# Storage backends
#   STORE: memory|postgres   CACHE: memory|redis
# memory = no infra (lost on restart). postgres/redis need the URLs below.
# =============================================================================
STORE=memory
CACHE=memory
# Required when STORE=postgres:
# DATABASE_URL=postgres://portal:portal@localhost:5432/portal?sslmode=disable
# Max open Postgres connections in the pool.
DATABASE_MAX_CONNS=20
# Required when CACHE=redis:
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Auth - must be "oidc" (real Keycloak login; the OIDC_* + SESSION_* vars below
# apply). The no-Keycloak "dev" mode is a test stub (internal/auth/dev.go) and is
# rejected at startup.
# =============================================================================
AUTH_MODE=oidc

# --- OIDC (only when AUTH_MODE=oidc) ---
# Issuer URL — must match the `iss` Keycloak puts in tokens (host-sensitive!).
# OIDC_ISSUER=http://localhost:8081/realms/internal
# OIDC_CLIENT_ID=portal
# OIDC_CLIENT_SECRET=portal-secret
# Callback the browser is redirected back to (must be allowed in the realm).
# OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback
# Where to send the browser after a successful login (usually the SPA root).
OIDC_POST_LOGIN_REDIRECT=/
# Where to send the browser after logout. Must be registered as a valid
# post-logout redirect URI on the Keycloak client. Defaults to the login value.
# OIDC_POST_LOGOUT_REDIRECT=http://localhost:5173/
# Scopes requested at login. "groups" is needed for RBAC (teams + admin).
OIDC_SCOPES=openid,profile,email,groups

# --- Session (used in oidc mode) ---
# Key for AES-256-GCM encryption of session values at rest (OIDC tokens +
# profile) in Redis. MUST be changed from this default: in AUTH_MODE=oidc the
# portal refuses to start while it equals the default.
SESSION_SECRET=dev-insecure-session-secret-change-me
SESSION_COOKIE_NAME=idp_session
SESSION_TTL=24h

# =============================================================================
# RBAC — derived from Keycloak (or any OIDC IdP) group claims
#   * teams: the prefix is matched against EACH segment of a group path, so a
#     prefixed segment anywhere resolves — "/group/group/team-core/group" -> "core".
#   * admin/support/security: membership in a RBAC_ADMIN_GROUPS / SUPPORT / SECURITY
#     group grants the role. Matched by the group's FULL path (leading slash
#     stripped), e.g. "platform-admins" matches "/platform-admins" but NOT a nested
#     "/x/platform-admins/y" - a subgroup cannot escalate to a privileged role.
#   * For an external IdP with a different/nested group structure, set
#     RBAC_TEAM_GROUP_REGEX instead — its first capture group becomes the team
#     name and it OVERRIDES the prefix. Examples:
#       RBAC_TEAM_GROUP_REGEX=(?:^|/)team-([^/]+)   # team-<team> anywhere in path
#       RBAC_TEAM_GROUP_REGEX=^/teams/([^/]+)$      # /teams/<team>
# =============================================================================
RBAC_TEAM_GROUP_PREFIX=team-
# RBAC_TEAM_GROUP_REGEX=
# Comma-separated. Empty => nobody is admin (everyone is member/auditor).
# RBAC_ADMIN_GROUPS=platform-admins
# Support role: cross-team view/edit of orders (no create/delete). Comma-separated.
# RBAC_SUPPORT_GROUPS=support
# Security role (InfoSec): security panel, policy orders (no team). Comma-separated.
# RBAC_SECURITY_GROUPS=security

# =============================================================================
# Harbor (chart registry) — only when HARBOR_MODE=real
# =============================================================================
# Base URL, no /api/v2.0 suffix.
# HARBOR_URL=https://host.docker.internal:8084
# Projects surfaced in the catalog (comma-separated). Default below.
HARBOR_PROJECTS=platform,managed-services
# Robot/account creds for private projects. Empty => anonymous (public project).
# HARBOR_ROBOT_USER=
# HARBOR_ROBOT_TOKEN=
# Skip TLS verification (the stand uses a self-signed cert).
HARBOR_INSECURE_TLS=false
# Per-request timeout for Harbor API/OCI calls.
HARBOR_TIMEOUT=30s
# Reserved: shared secret to authenticate inbound Harbor webhooks. Not yet wired.
# HARBOR_WEBHOOK_SECRET=

# =============================================================================
# GitLab (GitOps repos + merge requests) — only when GITLAB_MODE=real
# =============================================================================
# GITLAB_URL=http://localhost:8929
# Personal access token (api scope) the portal uses to create repos/MRs.
# GITLAB_TOKEN=glpat-localdev0123456789abcd
GITLAB_TIMEOUT=30s
# When true the status poller merges the portal's own MRs (no human gate) —
# handy for demos. When false, MRs wait for a human/automation to merge.
GITLAB_AUTO_MERGE=false
# Top-level group the GitOps repos live under.
GITLAB_GITOPS_GROUP=managed-services
# Go-template for a team's subgroup path under the GitOps group.
GITLAB_TEAM_SUBGROUP_TEMPLATE=team-{{.Team}}
# Default branch the portal commits to / Argo tracks.
GITLAB_DEFAULT_BRANCH=main
# Reserved: secret token to verify inbound GitLab webhooks. Not yet wired.
# GITLAB_WEBHOOK_TOKEN=

# =============================================================================
# Argo CD (deployment) — only when ARGOCD_MODE=real
# =============================================================================
# ARGOCD_URL=http://localhost:8083
# Long-lived API token. Mint with `make stand-token`; stand-up also prints it.
# ARGOCD_TOKEN=
# AppProject the portal's Applications belong to.
ARGOCD_PROJECT=portal-managed
# Default destination cluster name (Argo destination.name).
ARGOCD_DEFAULT_CLUSTER=in-cluster
# Go-template for the generated Application name. Includes the chart so two
# different charts ordered with the same service_name into one namespace do not
# collide on a single Application CR (vars: .Team, .Chart, .ServiceName).
ARGOCD_APP_NAME_TEMPLATE={{.Team}}-{{.Chart}}-{{.ServiceName}}
# OCI/Helm registry base baked into the committed application.yaml chart source;
# the chart repoURL becomes "{CHART_REGISTRY}/{chart_project}". On the stand this
# is the Harbor OCI endpoint, e.g. host.docker.internal:8084 (MUST be a host both
# the portal and the Argo pods can resolve). Empty in fakes-only mode.
# CHART_REGISTRY=host.docker.internal:8084

# =============================================================================
# Status tracking
# =============================================================================
# How often the poller reconciles request status against GitLab/Argo.
STATUS_POLL_INTERVAL=15s
# Reverse sync: flag orders whose committed Git state (values.yaml / chart
# version) was changed outside the portal. Read-only — never overwrites Git.
# Adds a couple of GitLab reads per active order each poll tick; set false to
# disable entirely.
DRIFT_DETECTION_ENABLED=true
# Discovery: adopt application.yaml manifests created directly in Git (bypassing
# the portal) as IMPORTED orders, so they show up in the catalog. Off by default
# because it CREATES order rows. Read-only w.r.t. Git.
IMPORT_DISCOVERY_ENABLED=false
# Autodiscovery: register charts found in Harbor as draft publications (owned by
# the admin group) so they surface in the catalog for curation. Off by default
# because it CREATES publication rows for every chart in the scanned projects.
CATALOG_AUTODISCOVER=false
# Reserved: intended to switch polling vs webhook-driven updates. Currently the
# poller always runs regardless of this value. Not yet wired.
STATUS_UPDATE_MODE=polling

# =============================================================================
# Observability
# =============================================================================
# LOG_LEVEL: debug|info|warn|error    LOG_FORMAT: json|text
LOG_LEVEL=info
LOG_FORMAT=json
