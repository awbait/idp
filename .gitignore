# Binaries
/portal
/bin/
*.exe

# Env / secrets
.env
*.pem
*.key

# Go
/vendor/

# Frontend
node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo
*.log

# Embedded SPA: only the placeholder is tracked; real assets are injected at
# image build time (see Dockerfile), never committed.
internal/spa/dist/*
!internal/spa/dist/index.html

# Helm packaging artifacts
*.tgz

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store

# Claude local settings (skills are tracked)
.claude/settings.local.json

# Docs: work in progress, not tracked for now
/docs/
